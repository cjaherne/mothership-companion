# OpenAI - For AI SDK, TTS (briefing voice), and click-to-talk voice
# Get key at https://platform.openai.com/api-keys (no URL config needed)
# Note: variable must be OPENAI_API_KEY (not OPEN_API_KEY)
OPENAI_API_KEY=

# Replicate - For character artwork generation (SDXL img2img)
# Get your token at https://replicate.com/account/api-tokens (starts with r8_)
# REPLICATE_API_TOKEN=r8_your_token_here

# Click-to-talk voice API: STT (Whisper), LLM (gpt-4o-mini), and TTS all use OpenAI.

# Optional: Deepgram for STT (if using STT-LLM-TTS pipeline)
# DEEPGRAM_API_KEY=

# Optional: Cartesia/ElevenLabs for TTS (if using STT-LLM-TTS pipeline)
# CARTESIA_API_KEY=

# Admin auth (required for hosted deployment; run npm run generate-admin-credentials for local)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
SESSION_SECRET=

